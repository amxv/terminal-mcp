{
  "name": "terminal-mcp",
  "version": "0.9.1",
  "description": "CLI to interact with MCP Streamable-HTTP server",
  "license": "MIT",
  "scripts": {
    "dev": "bun run src/cli.ts",
    "build:linux-x64": "bun build ./src/cli.ts --compile --minify --sourcemap --bytecode --target=bun-linux-x64 --outfile dist/terminal-mcp-linux-x64 --define BUILD_VERSION=\\\"$(node -p 'require(\"./package.json\").version')\\\"",
    "build:linux-arm64": "bun build ./src/cli.ts --compile --minify --sourcemap --bytecode --target=bun-linux-arm64 --outfile dist/terminal-mcp-linux-arm64 --define BUILD_VERSION=\\\"$(node -p 'require(\"./package.json\").version')\\\"",
    "build:macos-arm64": "bun build ./src/cli.ts --compile --minify --sourcemap --bytecode --target=bun-darwin-arm64 --outfile dist/terminal-mcp-macos-arm64 --define BUILD_VERSION=\\\"$(node -p 'require(\"./package.json\").version')\\\"",
    "build:macos-x64": "bun build ./src/cli.ts --compile --minify --sourcemap --bytecode --target=bun-darwin-x64 --outfile dist/terminal-mcp-macos-x64 --define BUILD_VERSION=\\\"$(node -p 'require(\"./package.json\").version')\\\"",
    "build:agent-linux-x64": "bun build ./src/cli-agent.ts --compile --minify --sourcemap --bytecode --target=bun-linux-x64 --outfile dist/terminal-mcp-agent-linux-x64 --define BUILD_VERSION=\\\"$(node -p 'require(\"./package.json\").version')\\\"",
    "build:agent-linux-arm64": "bun build ./src/cli-agent.ts --compile --minify --sourcemap --bytecode --target=bun-linux-arm64 --outfile dist/terminal-mcp-agent-linux-arm64 --define BUILD_VERSION=\\\"$(node -p 'require(\"./package.json\").version')\\\"",
    "build:agent-macos-arm64": "bun build ./src/cli-agent.ts --compile --minify --sourcemap --bytecode --target=bun-darwin-arm64 --outfile dist/terminal-mcp-agent-macos-arm64 --define BUILD_VERSION=\\\"$(node -p 'require(\"./package.json\").version')\\\"",
    "build:agent-macos-x64": "bun build ./src/cli-agent.ts --compile --minify --sourcemap --bytecode --target=bun-darwin-x64 --outfile dist/terminal-mcp-agent-macos-x64 --define BUILD_VERSION=\\\"$(node -p 'require(\"./package.json\").version')\\\"",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:macos-arm64 && bun run build:macos-x64 && bun run build:agent-linux-x64 && bun run build:agent-linux-arm64 && bun run build:agent-macos-arm64 && bun run build:agent-macos-x64",
    "build:current": "if [ \"$(uname)\" = \"Darwin\" ]; then if [ \"$(uname -m)\" = \"arm64\" ]; then bun run build:macos-arm64; else bun run build:macos-x64; fi; else if [ \"$(uname -m)\" = \"aarch64\" ]; then bun run build:linux-arm64; else bun run build:linux-x64; fi; fi",
    "build:agent-current": "if [ \"$(uname)\" = \"Darwin\" ]; then if [ \"$(uname -m)\" = \"arm64\" ]; then bun run build:agent-macos-arm64; else bun run build:agent-macos-x64; fi; else if [ \"$(uname -m)\" = \"aarch64\" ]; then bun run build:agent-linux-arm64; else bun run build:agent-linux-x64; fi; fi",
    "build": "./scripts/build.sh",
    "clean": "rm -rf dist",
    "release": "./scripts/release.sh",
    "release:patch": "./scripts/release.sh patch",
    "release:minor": "./scripts/release.sh minor",
    "release:major": "./scripts/release.sh major",
    "prerelease": "./scripts/prerelease.sh",
    "prerelease:alpha": "./scripts/prerelease.sh alpha",
    "prerelease:beta": "./scripts/prerelease.sh beta",
    "prerelease:rc": "./scripts/prerelease.sh rc",
    "status": "./scripts/status.sh",
    "changelog": "./scripts/changelog.sh",
    "test": "./scripts/test-runner.sh",
    "test:ci": "./scripts/ci-test.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.1"
  },
  "devDependencies": {
    "@types/bun": "^1.2.17"
  }
}
